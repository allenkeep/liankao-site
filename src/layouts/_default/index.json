{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
{{- $.Scratch.Add "index" (dict "title" .Title "description" .Description "tags" .Params.tags "categories" .Params.categories "permalink" .Permalink "date" (.Date.Format "2006-01-02") "section" .Section) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
